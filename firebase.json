{
  "hosting": {
    "public": "src/main/resources/static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "frontend/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
